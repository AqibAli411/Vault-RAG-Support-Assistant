# Vault AI Terminal - Environment Configuration

# 1. API Keys (Required)
# Retrieve this from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# The model choice for fast completions
GROQ_MODEL=llama-3.1-8b-instant

# 2. Authentication Secrets (Required)
# Generate a secret key using: openssl rand -hex 32
JWT_SECRET_KEY=replace_this_with_a_long_secure_random_string

# 3. Vector Database Connectivity (Optional defaults for Dev)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./backend/chroma-data

# 4. HuggingFace Embeddings (Optional)
# If you get rate limited downloading the embedding model.
# HF_TOKEN=your_huggingface_token_here
